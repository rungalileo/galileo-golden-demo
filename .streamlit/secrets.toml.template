# -----------------------------------------------------------------------------
# Each project has its own API key - you need both to create vector databases
# for both local development and hosted/production environments.
pinecone_api_key_local = ""    # For galileo-demo-local Pinecone project
pinecone_api_key_hosted = ""   # For galileo-demo-hosted Pinecone project

# Environment Configuration
# -----------------------------------------------------------------------------
# Set to "local" for local development, "hosted" for production/deployed demos
# This determines which Pinecone project is used for vector storage.
environment = "local"

# Live Finance Data (Optional)
# -----------------------------------------------------------------------------
# Alpha Vantage API key for backup stock data source.
# Get a free key at: https://www.alphavantage.co/support/#api-key
# Note: Yahoo Finance (yfinance) is used as the primary source and requires no key.
alpha_vantage_api_key = ""

# Observability Platforms (Optional)
# -----------------------------------------------------------------------------
# OpenTelemetry Platforms (Phoenix / Arize AX)
# NOTE: Phoenix and Arize AX are mutually exclusive but can be toggled instantly in the UI.
# -----------------------------------------------------------------------------

# Phoenix (Arize's hosted OpenTelemetry platform)
PHOENIX_ENDPOINT = "https://app.phoenix.arize.com/v1/traces"  # Standard Phoenix endpoint
PHOENIX_API_KEY = ""              # Your Phoenix API key
# PHOENIX_PROJECT_NAME = "galileo-demo"  # Optional: Override project name (fixed at startup)

# Arize AX (Arize Platform with OpenTelemetry)
ARIZE_API_KEY = ""                # Your Arize API key
ARIZE_SPACE_ID = ""               # Your Arize Space ID
# Note: Arize project name changes dynamically per domain (e.g., galileo-demo-finance)

